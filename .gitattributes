mocword filter=lfs diff=lfs merge=lfs -text

# Normalize text files to LF in this repository.
* text=auto eol=lf

# Keep shell/config/source files LF explicitly.
*.sh text eol=lf
*.zsh text eol=lf
*.bash text eol=lf
*.lua text eol=lf
*.vim text eol=lf
*.tmux.conf text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.tsv text eol=lf
*.conf text eol=lf
